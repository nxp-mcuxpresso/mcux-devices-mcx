/* Entry Point */
ENTRY(Reset_Handler)

HEAP_SIZE  = DEFINED(__heap_size__)  ? __heap_size__  : 0x0400;
STACK_SIZE = DEFINED(__stack_size__) ? __stack_size__ : 0x0400;
/* rpmsg-lite shared memory. Only reserved when the application opts in by
 * defining __use_shmem__ (see the rpmsg example reconfig.cmake). Carved from
 * the otherwise unused m_stdby_ram window so neither core's m_data is touched.
 * Both M7 cores share the same physical SRAM, so a single fixed base works.
 * The secondary receives this base from the primary at runtime via MCMGR
 * startup data; the region is declared here so the files stay symmetric. */
RPMSG_SHMEM_SIZE = DEFINED(__use_shmem__) ? 0x1800 : 0;


m_itcm_start             = 0x00000000;
m_itcm_end               = 0x00007FFF;

m_dtcm_start             = 0x20000000;
m_dtcm_end               = 0x2000FFFF;

m_stdby_ram_start        = 0x20400000;
m_stdby_ram_end          = 0x20407FFF;

/* The secondary core (M7_1) image is linked to run in place from this flash
 * window, embedded inside the primary flash image and programmed together
 * with it. M7_1 is released by writing this base to MC_ME PRTN0_CORE1_ADDR.
 * Matches m_core1_image_start in MCXE32B_cm7_core0_flash.ld. */
m_interrupts_start       = 0x00600000;
m_interrupts_end         = m_interrupts_start + 0x000003FF;

m_boot_header_start      = 0x00400000;
m_boot_header_end        = 0x004000FF;

m_text_start             = m_interrupts_end + 1;
m_text_end               = 0x0063FFFF;

/* Shared SRAM is split into two disjoint halves so the primary (M7_0) and the
 * secondary (M7_1) never use the same RAM. core1 owns the upper 144 KB; core0
 * owns the lower 144 KB (see MCXE32B_cm7_core0_flash.ld). The whole window is
 * 0x20408000..0x2044FFFF (288 KB). */
m_data_start             = 0x2042C000;
m_data_end               = 0x2044FFFF;

m_ncache_size            = 0x00004000;
m_ncache_start           = m_dtcm_start;
m_ncache_end             = m_ncache_start + m_ncache_size - 1;

m_qacode_start           = m_itcm_start;
m_qacode_end             = m_itcm_end;
m_qadata_start           = m_ncache_end + 1;
m_qadata_end             = m_dtcm_end;

/* Specify the memory areas */
/* The flash memory region [0x007D4000-0x7FFFFF] is reserved for security. */
MEMORY
{
  m_boot_header         (RX)  : ORIGIN = m_boot_header_start, LENGTH = m_boot_header_end - m_boot_header_start + 1
  m_interrupts          (RX)  : ORIGIN = m_interrupts_start,  LENGTH = m_interrupts_end - m_interrupts_start + 1
  m_text                (RX)  : ORIGIN = m_text_start,        LENGTH = m_text_end - m_text_start + 1
  rpmsg_sh_mem          (RW)  : ORIGIN = m_stdby_ram_start,   LENGTH = RPMSG_SHMEM_SIZE
  m_data                (RW)  : ORIGIN = m_data_start,        LENGTH = m_data_end - m_data_start + 1
  m_ncache              (RW)  : ORIGIN = m_ncache_start,      LENGTH = m_ncache_size

  m_qacode              (RW)  : ORIGIN = m_qacode_start,      LENGTH = m_qacode_end - m_qacode_start + 1
  m_qadata              (RW)  : ORIGIN = m_qadata_start,      LENGTH = m_qadata_end - m_qadata_start + 1
  m_itcm0_backdoor      (RW)  : ORIGIN = 0x11000000,          LENGTH = 0x11007FFF
  m_dtcm0_backdoor      (RW)  : ORIGIN = 0x21000000,          LENGTH = 0x2100FFFF
}

/* Define output sections */
SECTIONS
{
  .boot_header :
  {
    . = ALIGN(4);
    KEEP(*(.boot_header))    /* IVT */
    . = ALIGN(4);
  } > m_boot_header

  /* NOINIT section for rpmsg_sh_mem (only present when __use_shmem__ is set) */
  .noinit_rpmsg_sh_mem (NOLOAD) : ALIGN(4)
  {
     __RPMSG_SH_MEM_START__ = .;
     *(.noinit.$rpmsg_sh_mem*)
     . = ALIGN(4) ;
     __RPMSG_SH_MEM_END__ = .;
  } > rpmsg_sh_mem

  /* The startup code goes first into internal flash */
  .interrupts :
  {
    . = ALIGN(4);
    KEEP(*(.isr_vector))     /* Startup code */

    . = ALIGN(4);
  } > m_interrupts

  /* The program code and other data goes into internal flash */
  .text :
  {
    . = ALIGN(4);
    *(.text)                 /* .text sections (code) */
    *(.text*)                /* .text* sections (code) */
    *(.rodata)               /* .rodata sections (constants, strings, etc.) */
    *(.rodata*)              /* .rodata* sections (constants, strings, etc.) */
    *(.glue_7)               /* glue arm to thumb code */
    *(.glue_7t)              /* glue thumb to arm code */
    *(.eh_frame)
    KEEP (*(.init))
    KEEP (*(.fini))
    . = ALIGN(4);
  } > m_text

  .ARM.extab :
  {
    *(.ARM.extab* .gnu.linkonce.armextab.*)
  } > m_text

  .ARM :
  {
    __exidx_start = .;
    *(.ARM.exidx*)
    __exidx_end = .;
  } > m_text

 .ctors :
  {
    __CTOR_LIST__ = .;
    /* gcc uses crtbegin.o to find the start of
       the constructors, so we make sure it is
       first.  Because this is a wildcard, it
       doesn't matter if the user does not
       actually link against crtbegin.o; the
       linker won't look for a file to match a
       wildcard.  The wildcard also means that it
       doesn't matter which directory crtbegin.o
       is in.  */
    KEEP (*crtbegin.o(.ctors))
    KEEP (*crtbegin?.o(.ctors))
    /* We don't want to include the .ctor section from
       from the crtend.o file until after the sorted ctors.
       The .ctor section from the crtend file contains the
       end of ctors marker and it must be last */
    KEEP (*(EXCLUDE_FILE(*crtend?.o *crtend.o) .ctors))
    KEEP (*(SORT(.ctors.*)))
    KEEP (*(.ctors))
    __CTOR_END__ = .;
  } > m_text

  .dtors :
  {
    __DTOR_LIST__ = .;
    KEEP (*crtbegin.o(.dtors))
    KEEP (*crtbegin?.o(.dtors))
    KEEP (*(EXCLUDE_FILE(*crtend?.o *crtend.o) .dtors))
    KEEP (*(SORT(.dtors.*)))
    KEEP (*(.dtors))
    __DTOR_END__ = .;
  } > m_text

  .preinit_array :
  {
    PROVIDE_HIDDEN (__preinit_array_start = .);
    KEEP (*(.preinit_array*))
    PROVIDE_HIDDEN (__preinit_array_end = .);
  } > m_text

  .init_array :
  {
    PROVIDE_HIDDEN (__init_array_start = .);
    KEEP (*(SORT(.init_array.*)))
    KEEP (*(.init_array*))
    PROVIDE_HIDDEN (__init_array_end = .);
  } > m_text

  .fini_array :
  {
    PROVIDE_HIDDEN (__fini_array_start = .);
    KEEP (*(SORT(.fini_array.*)))
    KEEP (*(.fini_array*))
    PROVIDE_HIDDEN (__fini_array_end = .);
  } > m_text

  __etext = .;    /* define a global symbol at end of code */
  __DATA_ROM = .; /* Symbol is used by startup for data initialization */

  /* reserve MTB memory at the beginning of m_data */
  .mtb : /* MTB buffer address as defined by the hardware */
  {
    . = ALIGN(8);
    _mtb_start = .;
    KEEP(*(.mtb_buf)) /* need to KEEP Micro Trace Buffer as not referenced by application */
    . = ALIGN(8);
    _mtb_end = .;
  } > m_data

  .data : AT(__DATA_ROM)
  {
    . = ALIGN(4);
    __DATA_RAM = .;
    __data_start__ = .;      /* create a global symbol at data start */
    *(.data)                 /* .data sections */
    *(.data*)                /* .data* sections */
    KEEP(*(.jcr*))
    . = ALIGN(4);
    __data_end__ = .;        /* define a global symbol at data end */
  } > m_data

  __ram_function_flash_start = __DATA_ROM + (__data_end__ - __data_start__); /* Symbol is used by startup for initialization */
  .ram_function : AT(__ram_function_flash_start)
  {
    . = ALIGN(8);
    __ram_function_start__ = .;
    *(CodeQuickAccess)
    . = ALIGN(8);
    __ram_function_end__ = .;
  } > m_qacode

  __qadata_flash_start = __ram_function_flash_start + (__ram_function_end__ - __ram_function_start__);
  .qadata : AT(__qadata_flash_start)
  {
    . = ALIGN(4);
    __qadata_start__ = .;
    *(DataQuickAccess)
    . = ALIGN(4);
    __qadata_end__ = .;
  } > m_qadata

  __noncache_data_flash_start = __qadata_flash_start + (__qadata_end__ - __qadata_start__);
  .ncache.init : AT(__noncache_data_flash_start)
  {
    . = ALIGN(8);
    __noncache_data_start__ = .;      /* create a global symbol at ncache data start */
    *(NonCacheable.init)
    . = ALIGN(8);
    __noncache_data_end__ = .;   /* create a global symbol at ncache data end */
  } > m_ncache

  .ncache :
  {
    . = ALIGN(8);
    __noncache_bss_start__ = .;  /* define a global symbol at ncache bss start */
    *(NonCacheable)
    . = ALIGN(8);
    __noncache_bss_end__ = .;    /* define a global symbol at ncache bss end */
  } > m_ncache

  __DATA_END = __noncache_data_flash_start + (__noncache_data_end__ - __noncache_data_start__);
  text_end = ORIGIN(m_text) + LENGTH(m_text);
  ASSERT(__DATA_END <= text_end, "region m_text overflowed with text and data")

  /* Uninitialized data section */
  .bss :
  {
    /* This is used by the startup in order to initialize the .bss section */
    . = ALIGN(4);
    __START_BSS = .;
    __bss_start__ = .;
    *(.bss)
    *(.bss*)
    *(COMMON)
    . = ALIGN(4);
    __bss_end__ = .;
    __END_BSS = .;
  } > m_data

  .heap :
  {
    . = ALIGN(8);
    __end__ = .;
    PROVIDE(end = .);
    __HeapBase = .;
    . += HEAP_SIZE;
    __HeapLimit = .;
    __heap_limit = .; /* Add for _sbrk */
  } > m_data

  .stack :
  {
    . = ALIGN(8);
    . += STACK_SIZE;
  } > m_data

  /* Initializes stack on the end of block */
  __StackTop   = ORIGIN(m_data) + LENGTH(m_data);
  __StackLimit = __StackTop - STACK_SIZE;
  PROVIDE(__stack = __StackTop);

  .ARM.attributes 0 : { *(.ARM.attributes) }

  ASSERT(__StackLimit >= __HeapLimit, "region m_data overflowed with stack and heap")
}
